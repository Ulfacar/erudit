# On-prem Bilim OS. Copy to .env.onprem and fill real values.
# Generate passwords/secrets on the server, do not commit .env.onprem.

# Required: public domains, both A-records must point to this server.
DOMAIN=school.example.com
MINIO_DOMAIN=media.school.example.com
ACME_EMAIL=admin@example.com

# Required: Postgres. Generate password: openssl rand -hex 24
POSTGRES_USER=bilimos
POSTGRES_PASSWORD=change-me-generate-with-openssl
POSTGRES_DB=bilimos

# Required: auth. Generate secret: openssl rand -base64 32
# Empty NEXTAUTH_SECRET causes login 500.
NEXTAUTH_SECRET=change-me-generate-with-openssl
NEXTAUTH_URL=https://school.example.com

# Demo data runs ONLY when SEED_DEMO is exactly 1. Real school: keep 0 (or unset).
# Any other value / unset = no demo seeds, no demo accounts (fail-safe by default).
SEED_DEMO=0

# Required ONLY on a demo stand (SEED_DEMO=1): shared password for ALL demo accounts
# (role demo users + demo college counselor). No default in code — if SEED_DEMO=1 and this
# is empty, every demo seed aborts before touching the database (no user is created/updated).
# On a real school (SEED_DEMO unset/0) this is irrelevant. Generate: openssl rand -base64 18
SEED_DEMO_PASSWORD=

# Required: MinIO through Caddy TLS. Generate secret key: openssl rand -hex 24
MINIO_ENDPOINT=media.school.example.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=bilimos
MINIO_SECRET_KEY=change-me-generate-with-openssl
MINIO_BUCKET=psy
MINIO_REGION=us-east-1

# Optional push notifications. Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Optional AI provider. Empty values degrade softly where supported.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_VISION_MODEL=

# Optional Telegram integration.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Optional SMTP notifications.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional WhatsApp/SMS integrations.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
SMS_API_URL=
SMS_API_KEY=

# Optional cron and psychology settings.
CRON_SECRET=
PSY_STRICT_PRIVACY=
PSY_ESCALATION_HOURS=
PSY_REMIND_HOURS=
