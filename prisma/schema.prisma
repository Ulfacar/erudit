// ============ MAINTENANCE / АХЧ ============

enum MaintenanceStatus {
  open
  in_progress
  done
  cancelled
}

model Asset {
  id        String   @id @default(cuid())
  name      String
  inventoryNo String?
  location  String?  // кабинет/этаж
  category  String?  // мебель | техника | инвентарь
  quantity  Int      @default(1)
  condition String?  // новое | рабочее | требует ремонта | списано
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
