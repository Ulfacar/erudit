  id         String   @id @default(cuid())
  studentId  String
  contractId String?  // привязка к договору (для графика платежей по договору)
  title      String   // "Обучение, сентябрь" и т.п.
  period     String?  // месяц/триместр
  amount     Int      // в сомах
  status     InvoiceStatus @default(pending)
  dueDate    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  contract Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  payments Payment[]

  @@index([studentId])
  @@index([contractId])
  @@index([status])
}

model Payment {
  id         String     @id @default(cuid())
  invoiceId  String
  invoice    FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount     Int
  method     String? // нал | карта | мбанк | банк
  paidAt     DateTime   @default(now())
  note       String?
  // Верификация (UC бухгалтерии): колл-центр помечает «принято со слов», бухгалтер подтверждает.
  verified   Boolean    @default(false)
  verifiedBy String? // user.id бухгалтера
  verifiedAt DateTime?
  receiptKey String? // чек/квитанция в MinIO (доказательство)
  recordedBy String? // кто внёс (колл-центр/бухгалтер)

  @@index([invoiceId])
}

model Expense {
  id        String   @id @default(cuid())
  category  String   // зарплата | коммуналка | закуп | ремонт
  title     String
  amount    Int
  date      DateTime
  authorId  String
  branchId  String? // филиал расхода (multi-branch)
  createdAt DateTime @default(now())

  @@index([category])
  @@index([date])
}

// ============ ДОГОВОРЫ (приёмная) ============
enum ContractStatus {
  draft
  active
  completed
  cancelled
}

model Contract {
  id             String          @id @default(cuid())
  number         String // номер договора
  studentId      String
  branchId       String?
  year           String // учебный год, напр. «2026–2027»
  baseAmount     Int // стоимость до скидки
  discountPct    Int             @default(0)
  discountNote   String? // за что скидка
  amount         Int // итог со скидкой
  prepaymentPct  Int             @default(0)
  scheduleType   PaymentSchedule @default(monthly)
  scheduleMonths Int             @default(9)
  paymentDay     Int             @default(10) // день оплаты
  representative Json? // {fio, inn, phone}
  requisites     Json? // реквизиты школы (из филиала)
  status         ContractStatus  @default(active)
  prevContractId String? // история перезаключений
  startDate      DateTime?
  createdById    String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  invoices FeeInvoice[]

  @@index([studentId])
  @@index([branchId])
}

// Резерв/очередь в класс (на первый класс ~100 человек в очереди).
model ClassReserveEntry {
  id          String    @id @default(cuid())
  classId     String
  leadId      String?
  childName   String
  parentName  String?
  parentPhone String?
  dateOfBirth DateTime?
  desiredYear String?
  position    Int       @default(0)
  status      String    @default("waiting") // waiting | enrolled | cancelled
  branchId    String?
  note        String?
  createdAt   DateTime  @default(now())

  @@index([classId, position])
}

// ============ KITCHEN / MEALS ============

enum MealType {
  breakfast
  lunch
  snack
}

model MealMenu {
  id        String   @id @default(cuid())
  date      DateTime
  meal      MealType
  dish      String
  calories  Int?
  cost      Int?
  createdAt DateTime @default(now())

  @@index([date, meal])
}

model MealPlan {
