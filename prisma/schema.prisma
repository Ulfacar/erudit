generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ФИЛИАЛЫ (multi-branch) ============
// Школа Эмира многофилиальная. branchId проставляется сущностям; скоупинг —
// server-side через branch-scope.ts. super_admin/analyst видят все филиалы.
model Branch {
  id         String   @id @default(cuid())
  name       String
  address    String?
  requisites Json? // ИНН, расчётные счета, реквизиты для договоров
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

// ============ AUTH & ROLES ============

model User {
  id        String   @id @default(cuid())
  login     String   @unique
  email     String?  @unique
  password  String
  role      Role
  starLevel Int      @default(1)
  isActive  Boolean  @default(true)
  branchId  String? // домашний филиал сотрудника (null = все, для super_admin/analyst)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Привязка к Telegram-боту для доставки уведомлений агента (опц.)
  telegramChatId   String?
  telegramLinkCode String? @unique
  telegramPendingRequest String?

  teacher Teacher?
  student Student?
  parent  Parent?

  pushSubscriptions PushSubscription[]
}

// Web-push подписка браузера/PWA (у пользователя может быть несколько устройств)
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

enum Role {
  super_admin
  founder
  analyst
  zavuch
  secretary
  teacher
  curator
  specialist // широкий специалист (логопед/универсал — все три кабинета)
  student
  parent
  // Узкие роли сотрудников (этап 4: «заходишь как бухгалтер — другие функции»)
  accountant // бухгалтер
  chief_accountant // главный бухгалтер
  finance_manager // финансист
  psychologist // психолог (kind=psych)
  doctor // врач (kind=medical)
  hr // кадровик
  librarian // библиотекарь
  cook // повар/столовая
  zavhoz // завхоз/АХЧ
  senior_psychologist // старший психолог: конструктор методик + надзор/эскалация (eSPSMS)
  psy_coordinator
  safeguarding_lead // координатор безопасности / воспитатель: происшествия, беседы, воспит. мероприятия
  call_center // колл-центр: обзвон задолжников, обещания оплаты
  event_manager // ивент-менеджер: школьные мероприятия, заслуги участникам
  media // медиа-центр
  // Завучи (наследуют доступ zavuch через ROLE_INHERITS; ступень-скоупинг — отдельно)
  zavuch_primary // завуч по младшим классам
  zavuch_senior // завуч по старшим классам
  zavuch_academic // завуч по учебной части
  cambridge_coord // Кэмбридж-координатор
  college_counselor
}

// ============ SCHOOL STRUCTURE ============

model SchoolLevel {
  id        String  @id @default(cuid())
  name      String
  fromGrade Int
  toGrade   Int
  classes   Class[]
}

model Class {
  id      String      @id @default(cuid())
  grade   Int
  letter  String
  levelId String
  level   SchoolLevel @relation(fields: [levelId], references: [id])
  branchId String? // филиал класса (multi-branch)
  capacity Int? // мест в классе (для резерва/очереди, M-A)

  curatorId String?
  curator   Teacher? @relation("CuratorOf", fields: [curatorId], references: [id])

  students        Student[]
  groups          ClassGroup[]
  scheduleEntries ScheduleEntry[]
  homework        Homework[]
  news            News[]
}

model ClassGroup {
  id        String    @id @default(cuid())
  name      String
  classId   String
  class     Class     @relation(fields: [classId], references: [id])
  students  Student[] @relation("StudentGroups")
  transfersFrom GroupTransfer[] @relation("TransferFromGroup")
  transfersTo   GroupTransfer[] @relation("TransferToGroup")
}

model GroupTransfer {
  id           String              @id @default(cuid())
  studentId    String
  classId      String
  fromGroupId  String
  toGroupId    String
  requestedBy  String              // teacher.id who initiated
  approvedBy   String?             // teacher.id who approved (if status='approved')
  status       GroupTransferStatus @default(pending)
  rejectReason String?             @db.VarChar(500)
  createdAt    DateTime            @default(now())
  decidedAt    DateTime?

  fromGroup ClassGroup @relation("TransferFromGroup", fields: [fromGroupId], references: [id])
  toGroup   ClassGroup @relation("TransferToGroup",   fields: [toGroupId],   references: [id])

  @@index([classId, status, createdAt])
  @@index([studentId])
}

enum GroupTransferStatus {
  pending
  approved
  rejected
}

// ============ PEOPLE ============

model Teacher {
  id         String    @id @default(cuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id])
  firstName  String
  lastName   String
  middleName String?
  position   String?
  photo      String?
  hireDate   DateTime?
  data       Json?

  subjects        TeacherSubject[]
  curatorOf       Class[]           @relation("CuratorOf")
  scheduleEntries ScheduleEntry[]
  substitutions   Substitution[]
  descriptors     TeacherDescriptor[]
  grades          Grade[]
  homework        Homework[]
}

/// Дескриптор педагога (по ТЗ): пометки о качестве работы, выговорах, штрафах,
/// повышениях, частых болезнях и т.п. с привязкой к учебному году.
/// Уровень доступа:
///   1 — общий: видим мы (super_admin), завучи и сам педагог
///   2 — только завучи и super_admin
///   3 — только super_admin
model TeacherDescriptor {
  id          String   @id @default(cuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  year        Int      // учебный год начала (например 2025 = 2025-2026)
  text        String   @db.VarChar(2000)
  accessLevel Int      @default(1) // 1 / 2 / 3
  authorId    String   // user.id создателя
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teacherId, year])
  @@index([accessLevel])
}

model Student {
  id          String        @id @default(cuid())
  userId      String?       @unique
  user        User?         @relation(fields: [userId], references: [id])
  firstName   String
  lastName    String
  middleName  String?
  dateOfBirth DateTime?
  photo       String?
  status      StudentStatus @default(permanent)
  classId     String
  class       Class         @relation(fields: [classId], references: [id])
  enrolledAt  DateTime      @default(now())
  branchId    String? // филиал ученика (multi-branch)
  psyCode     String? // персональный номер участника психослужбы (У-####); уникальность гарантирует последовательный backfill (без DB-констрейнта — db push на @unique падал на проде)

  groups      ClassGroup[]    @relation("StudentGroups")
  grades      Grade[]
  attendance  Attendance[]
  parentLinks ParentStudent[]
  incidents   BehaviorIncident[]
  incidentParticipations IncidentParticipant[] @relation("IncidentParticipations")
  supervisionCases SupervisionCase[] @relation("SupervisionCases")
  mediationProtocols MediationProtocol[] @relation("MediationProtocols")
  feeInvoices FeeInvoice[]
  screeningResults PsyScreeningResult[]

  medicalData   Json?
  familyData    Json?
  financialData Json?
  ccProfile     CcProfile?
}

enum StudentStatus {
  permanent
  conditional
  repeating
  graduated // выпускник (после перевода года из последнего класса)
  withdrawn // отчислен (ушёл из школы)
}

// Запись об отчислении ученика (причина, дата) — модуль «Отчисления».
model Withdrawal {
  id        String   @id @default(cuid())
  studentId String
  reason    String
  date      DateTime @default(now())
  branchId  String?
  authorId  String
  createdAt DateTime @default(now())

  @@index([studentId])
}

model Parent {
  id        String @id @default(cuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id])
  firstName String
  lastName  String
  phone     String?

  children ParentStudent[]
}

model ParentStudent {
  parentId  String
  studentId String
  parent    Parent  @relation(fields: [parentId], references: [id])
  student   Student @relation(fields: [studentId], references: [id])
  relation  String

  @@id([parentId, studentId])
}

// Кросс-ролевые заметки по ученику для единого таймлайна («вся школа взаимосвязана»):
// обещания колл-центра, статусы приёмки, произвольные пометки разных ролей.
model StudentNote {
  id        String   @id @default(cuid())
  studentId String
  authorId  String
  role      String // роль автора на момент заметки
  type      String // promise | call | note | status | finance | psych
  text      String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([studentId, createdAt])
}

// ============ SUBJECTS & WORKLOAD ============

model Subject {
  id    String  @id @default(cuid())
  name  String
  color String?

  teachers        TeacherSubject[]
  grades          Grade[]
  scheduleEntries ScheduleEntry[]
  homework        Homework[]
}

model TeacherSubject {
  id           String  @id @default(cuid())
  teacherId    String
  subjectId    String
  classId      String
  hoursPerWeek Int     @default(0)
  teacher      Teacher @relation(fields: [teacherId], references: [id])
  subject      Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId, classId])
}

/// Запись о передаче нагрузки от одного учителя к другому (декрет, болезнь, увольнение).
/// По ТЗ: новый учитель видит все учебные даты, темы и оценки за период до transferredAt
/// в режиме read-only. Записи накапливаются при каждой передаче, чтобы цепочка была видна.
model TeacherLoadTransfer {
  id              String   @id @default(cuid())
  fromTeacherId   String
  toTeacherId     String
  subjectId       String
  classId         String
  reason          String?  @db.VarChar(500) // декрет, длительная болезнь, увольнение и т.п.
  transferredAt   DateTime @default(now())
  transferredBy   String   // user.id (завуч/super_admin)

  @@index([toTeacherId, classId, subjectId])
  @@index([fromTeacherId, classId, subjectId])
}

// ============ SCHEDULE ============

model BellSchedule {
  id         String   @id @default(cuid())
  slotNumber Int
  startTime  String
  endTime    String
  type       SlotType

  entries ScheduleEntry[]
}

enum SlotType {
  lesson
  break_time
  breakfast
  lunch
  snack
  dismissal
}

model ScheduleEntry {
  id          String   @id @default(cuid())
  classId     String
  teacherId   String
  subjectId   String
  slotId      String
  dayOfWeek   Int
  periodStart DateTime
  periodEnd   DateTime

  class   Class        @relation(fields: [classId], references: [id])
  teacher Teacher      @relation(fields: [teacherId], references: [id])
  subject Subject      @relation(fields: [subjectId], references: [id])
  slot    BellSchedule @relation(fields: [slotId], references: [id])

  @@index([classId, dayOfWeek, periodStart, periodEnd])
  @@index([teacherId, dayOfWeek, periodStart, periodEnd])
}

model Substitution {
  id                  String   @id @default(cuid())
  date                DateTime
  originalTeacherId   String
  substituteTeacherId String
  classId             String
  subjectId           String
  slotId              String
  reason              String?
  createdAt           DateTime @default(now())

  substitute Teacher @relation(fields: [substituteTeacherId], references: [id])
}

model TimeOffRequest {
  id                  String    @id @default(cuid())
  teacherId           String
  date                DateTime
  hours               Int
  reason              String?   @db.Text
  status              String    @default("pending")
  substituteTeacherId String?
  reviewedById        String?
  reviewedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([teacherId])
  @@index([status])
}

model TeacherHours {
  id        String   @id @default(cuid())
  teacherId String
  date      DateTime
  hours     Int
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([teacherId])
}

// ============ GRADING ============

model GradeCategory {
  id                  String  @id @default(cuid())
  name                String
  weight              Int
  order               Int
  // По ТЗ: на модерацию идут только Контрольные / Зачёт / Триместровая / Итоговая / Экзамен
  requiresModeration  Boolean @default(false)
  // По ТЗ: тип "проверочная работа" — настраиваемый чекбокс (для отчёта № 4)
  isAssessment        Boolean @default(false)
  // По ТЗ: учителя могут создавать собственные категории только при разрешении админа
  enabledForTeachers  Boolean @default(false)

  grades Grade[]
}

/// Назначение (EduPage-style): колонка журнала — классная/контрольная/домашняя
/// работа с количеством очков. Оценки привязываются к назначению.
model Assignment {
  id         String   @id @default(cuid())
  classId    String
  subjectId  String
  teacherId  String // teacher.id
  periodId   String
  title      String
  shortName  String? // короткая шапка колонки
  categoryId String? // тип работы (вес/модерация)
  maxPoints  Int      @default(100)
  date       DateTime
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  grades Grade[]

  @@index([classId, subjectId, periodId, date])
}

model Grade {
  id         String      @id @default(cuid())
  studentId  String
  subjectId  String
  categoryId String
  teacherId  String
  periodId   String
  /// привязка к назначению-колонке (EduPage); null = «прочие» оценки
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])
  value      Int
  scale      GradeScale  @default(FIVE)
  comment    String?     @db.VarChar(500)
  date       DateTime
  status     GradeStatus @default(draft)
  // EduPage: родитель/ученик «подписывает» оценку (подтверждает, что видел)
  parentSignedAt DateTime?
  parentSignedBy String?  // user.id родителя/ученика
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  student  Student        @relation(fields: [studentId], references: [id])
  subject  Subject        @relation(fields: [subjectId], references: [id])
  category GradeCategory  @relation(fields: [categoryId], references: [id])
  teacher  Teacher        @relation(fields: [teacherId], references: [id])
  period   AcademicPeriod @relation(fields: [periodId], references: [id])
  auditLog GradeAuditLog[]

  @@index([studentId, subjectId, periodId])
  @@index([status])
  @@index([assignmentId])
}

enum GradeStatus {
  draft
  submitted
  moderated
  published
}

enum GradeScale {
  FIVE
  TWELVE
  HUNDRED
  LETTER
}

model GradeAuditLog {
  id        String   @id @default(cuid())
  gradeId   String
  userId    String
  oldValue  Int?
  newValue  Int?
  action    String
  createdAt DateTime @default(now())

  grade Grade @relation(fields: [gradeId], references: [id])
}

// ============ ATTENDANCE ============

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  date      DateTime
  status    AttendanceStatus
  reason    String?          @db.VarChar(300) // причина отсутствия/освобождения (болезнь, справка и т.п.)

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
}

enum AttendanceStatus {
  present
  absent
  late
  excused
  trip
  quarantine
}

// ============ ACADEMIC PERIODS ============

model AcademicPeriod {
  id        String     @id @default(cuid())
  name      String
  type      PeriodType
  startDate DateTime
  endDate   DateTime
  isActive  Boolean    @default(false)

  grades Grade[]
}

enum PeriodType {
  trimester
  holiday
  quarantine
}

// ============ HOMEWORK ============

model Homework {
  id          String   @id @default(cuid())
  classId     String
  subjectId   String
  teacherId   String
  description String
  dueDate     DateTime
  createdAt   DateTime @default(now())

  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])
}

// ============ BEHAVIOR ============

model BehaviorIncident {
  id             String         @id @default(cuid())
  studentId      String
  reporterId     String
  type           String
  description    String
  level          BehaviorLevel  @default(low)
  status         IncidentStatus @default(pending)
  moderatedBy    String?
  moderatedAt    DateTime?
  parentNotified Boolean        @default(false)
  createdAt      DateTime       @default(now())

  student      Student               @relation(fields: [studentId], references: [id])
  participants IncidentParticipant[]
  supervisionCases SupervisionCase[]
  mediationProtocols MediationProtocol[]

  @@index([studentId, createdAt])
}

enum IncidentStatus {
  pending
  moderated
  resolved
}

enum IncidentRole {
  initiator
  victim
  accomplice
  witness
}

enum BehaviorLevel {
  low
  medium
  high
}

model IncidentParticipant {
  id                 String           @id @default(cuid())
  behaviorIncidentId String
  incident           BehaviorIncident @relation(fields: [behaviorIncidentId], references: [id], onDelete: Cascade)
  studentId          String
  student            Student          @relation("IncidentParticipations", fields: [studentId], references: [id], onDelete: Cascade)
  role               IncidentRole
  createdAt          DateTime         @default(now())

  @@unique([behaviorIncidentId, studentId])
  @@index([studentId])
}

enum SupervisionStatus {
  improved
  no_change
  needs_council
}

model SupervisionCase {
  id                 String             @id @default(cuid())
  studentId          String
  student            Student            @relation("SupervisionCases", fields: [studentId], references: [id], onDelete: Cascade)
  behaviorIncidentId String?
  incident           BehaviorIncident?  @relation(fields: [behaviorIncidentId], references: [id], onDelete: SetNull)
  reason             String
  sessionsPlanned    Int                @default(3)
  status             SupervisionStatus  @default(no_change)
  openedAt           DateTime           @default(now())
  monitoringUntil    DateTime?
  closedAt           DateTime?
  createdAt          DateTime           @default(now())

  @@index([studentId])
  @@index([behaviorIncidentId])
}

enum MediationParty {
  student
  parent
}

model MediationProtocol {
  id                 String                 @id @default(cuid())
  studentId          String
  student            Student                @relation("MediationProtocols", fields: [studentId], references: [id], onDelete: Cascade)
  behaviorIncidentId String?
  incident           BehaviorIncident?      @relation(fields: [behaviorIncidentId], references: [id], onDelete: SetNull)
  date               DateTime               @default(now())
  agreement          String                 @db.Text
  authorId           String
  createdAt          DateTime               @default(now())
  obligations        MediationObligation[]

  @@index([studentId])
  @@index([behaviorIncidentId])
}

model MediationObligation {
  id         String             @id @default(cuid())
  protocolId String
  protocol   MediationProtocol  @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  party      MediationParty
  task       String
  deadline   DateTime?
  done       Boolean            @default(false)
  doneAt     DateTime?
  createdAt  DateTime           @default(now())

  @@index([protocolId])
}

// ============ NEWS ============

model News {
  id          String   @id @default(cuid())
  title       String
  content     String
  type        NewsType
  authorId    String
  classId     String?
  class       Class?   @relation(fields: [classId], references: [id])
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum NewsType {
  school
  staff
  class_note
}

// ============ URGENT ISSUES ============

model UrgentIssue {
  id          String        @id @default(cuid())
  title       String
  description String
  priority    IssuePriority
  status      IssueStatus   @default(open)
  authorId    String
  visibleTo   String[]      // role names: ['zavuch', 'curator', 'super_admin']
  classId     String?
  studentId   String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum IssuePriority {
  high
  medium
  low
}

enum IssueStatus {
  open
  in_progress
  resolved
  closed
}

// ============ INCIDENTS ============

model Incident {
  id          String        @id @default(cuid())
  title       String
  description String
  type        IncidentType
  severity    IssuePriority
  status      IssueStatus   @default(open)
  authorId    String
  classId     String?
  studentId   String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum IncidentType {
  behavior
  health
  equipment
  safety
  other
}

// ============ CHAT ============

model ChatMessage {
  id        String   @id @default(cuid())
  senderId  String
  roomId    String
  content   String
  fileUrl   String?
  createdAt DateTime @default(now())
}

// ============ CALENDAR ============

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.VarChar(1000)
  date        DateTime
  endDate     DateTime?
  type        String   @default("event") // event | holiday | exam | meeting | deadline
  classId     String?  // null = общешкольное
  audience    String[] @default([]) // роли, для кого видно; пусто = все
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

// ============ CURRICULUM PLAN (КТП) ============

model CurriculumPlan {
  id        String   @id @default(cuid())
  subjectId String
  classId   String
  periodId  String?
  teacherId String?
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topics CurriculumTopic[]

  @@index([subjectId, classId])
}

model CurriculumTopic {
  id        String   @id @default(cuid())
  planId    String
  plan      CurriculumPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  order     Int
  title     String
  hours     Int      @default(1)
  plannedAt DateTime?
  done      Boolean  @default(false)

  @@index([planId, order])
}

// ============ ACHIEVEMENTS ============

model Achievement {
  id          String   @id @default(cuid())
  studentId   String
  title       String
  description String?  @db.VarChar(1000)
  category    String   @default("academic") // academic | sport | art | social | other
  level       String   @default("school")   // school | district | city | republic | international
  place       String?  // 1 место, призёр, участник и т.п.
  date        DateTime
  authorId    String
  eventId     String?  // источник — школьное мероприятие (SchoolEvent), если достижение из ивента
  createdAt   DateTime @default(now())

  @@index([studentId])
  @@index([eventId])
