}

model MediaRequest {
  id            String            @id @default(cuid())
  title         String
  description   String?           @db.VarChar(1000)
  location      String?
  date          DateTime?
  priority      IssuePriority     @default(medium)
  status        MaintenanceStatus @default(open)
  source        String?
  eventId       String?
  requesterId   String
  requesterName String?
  requesterRole String?
  assigneeId    String?
  assigneeName  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
}

// ============ LESSON TOPIC (тема урока, EduPage) ============

model PurchaseRequest {
  id             String    @id @default(cuid())
  title          String
  items          String?   @db.Text
  amount         Int?
  status         String    @default("pending")
  decisionNote   String?   @db.Text
  authorId       String?
  authorName     String?
  reviewedById   String?
  reviewedAt     DateTime?
  forwardedById  String?
  forwardedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([authorId])
  @@index([createdAt])
}

// Заявка из калькулятора тарифов (лид на подключение Bilim OS).
model TariffLead {
  id              String    @id @default(cuid())
  contactName     String
  contactPhone    String
  contactSchool   String?
  comment         String?   @db.Text
  standardModules Json?     // legacy string[] — имена выбранных обычных модулей
  heavyModules    Json?     // legacy string[] — имена выбранных тяжёлых модулей
  setupTotal      Int?
  licenseTotal    Int?
  schoolSize      String?
  pricingMode     String?
  presetId        String?
  selectedModules Json?
  weightTotal     Float?
  unitPrice       Int?
  annualLicence   Int?
  yearOne         Int?
  monthly         Int?
  aiInterest      Boolean   @default(false)
  pricingSnapshot Json?
  status          String    @default("new") // new | in_progress | won | lost
  decisionNote    String?   @db.Text
  authorId        String?
  authorName      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

model LessonTopic {
  id        String   @id @default(cuid())
  classId   String
  subjectId String
  teacherId String?
  date      DateTime
  topic     String   @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, subjectId, date])
  @@index([classId, subjectId])
}

// ============ HOMEWORK COMPLETION (отметка «выполнено») ============

model HomeworkCompletion {
  id         String   @id @default(cuid())
  homeworkId String
  studentId  String
  doneAt     DateTime @default(now())

  @@unique([homeworkId, studentId])
  @@index([homeworkId])
}

// ============ ЗАЯВЛЕНИЯ / ЗАПИСКА ОБ ОТСУТСТВИИ (Модуль 4) ============

enum ApplicationType {
  absence   // отпросить / записка об отсутствии
  leave     // отпуск
  other
}

enum ApplicationStatus {
  pending
  approved
  rejected
}

model Application {
  id         String   @id @default(cuid())
  type       ApplicationType   @default(absence)
  studentId  String
  classId    String?
  authorId   String   // user.id родителя/ученика, подавшего заявление
  reason     String   @db.VarChar(1000)
  fromDate   DateTime
  toDate     DateTime?
  status     ApplicationStatus @default(pending)
  reviewedBy String?  // user.id завуча/учителя
  reviewNote String?  @db.VarChar(500)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([studentId])
}

// ============ ОПРОСЫ / ГОЛОСОВАНИЯ (Модуль 5) ============

model Survey {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.VarChar(1000)
  options     String[] // варианты ответа
  audience    String[] @default([]) // роли; пусто = все
  authorId    String
  closesAt    DateTime?
  createdAt   DateTime @default(now())

  votes SurveyVote[]
}

model SurveyVote {
  id          String   @id @default(cuid())
  surveyId    String
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId      String
  optionIndex Int
  createdAt   DateTime @default(now())

  @@unique([surveyId, userId])
  @@index([surveyId])
}

// ============ ЗАКАЗ СТОЛОВОЙ (Модуль 6, поверх MealMenu) ============

model MealOrder {
  id        String   @id @default(cuid())
  date      DateTime
  meal      MealType
  studentId String
  status    String   @default("ordered") // ordered | cancelled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date, meal])
  @@index([date])
}

// ============ СОГЛАСИЯ РОДИТЕЛЕЙ + БЮРО НАХОДОК (Модуль 7) ============

model Consent {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.VarChar(1000)
  eventDate   DateTime?
  classId     String?
  authorId    String
  createdAt   DateTime @default(now())

  responses ConsentResponse[]
}

model ConsentResponse {
  id        String   @id @default(cuid())
  consentId String
  consent   Consent  @relation(fields: [consentId], references: [id], onDelete: Cascade)
  studentId String
  agreed    Boolean
  signedBy  String   // user.id родителя
  signedAt  DateTime @default(now())

  @@unique([consentId, studentId])
}

model LostFoundItem {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.VarChar(500)
  location    String?
  status      String   @default("found") // found | claimed | returned
  foundAt     DateTime @default(now())
  authorId    String
  createdAt   DateTime @default(now())
}

// ============ ТЕСТЫ С АВТОПРОВЕРКОЙ (Модуль 8, EduPage e-learning) ============

enum TestStatus {
  draft
  published
  closed
}

enum QuestionType {
  single    // один правильный вариант
  multiple  // несколько правильных
  number    // числовой ответ
  text      // открытый (проверяет учитель, авто-0)
}

model Test {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.VarChar(1000)
  subjectId   String?
  classId     String?
  authorId    String
  status      TestStatus @default(published)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions TestQuestion[]
  attempts  TestAttempt[]

  @@index([classId])
  @@index([authorId])
}

model TestQuestion {
  id             String   @id @default(cuid())
  testId         String
  test           Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  order          Int
  text           String   @db.VarChar(1000)
  type           QuestionType @default(single)
  options        String[] @default([])    // варианты (для single/multiple)
  correctAnswers String[] @default([])    // правильные: индексы вариантов или значение (number)
  points         Int      @default(1)

  @@index([testId, order])
}

model TestAttempt {
  id          String   @id @default(cuid())
  testId      String
  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  studentId   String
  score       Int      @default(0)
  maxScore    Int      @default(0)
  submittedAt DateTime @default(now())

  answers TestAnswer[]

  @@unique([testId, studentId])
  @@index([testId])
}

model TestAnswer {
  id            String   @id @default(cuid())
  attemptId     String
  attempt       TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId    String
  answer        String[] @default([])
  isCorrect     Boolean  @default(false)
  pointsAwarded Int      @default(0)

  @@index([attemptId])
}

/// ИИ-генератор презентаций (мультимодальный оркестратор учителя).
/// Учитель вводит тему → LLM (OpenRouter) выдаёт структурированные слайды.
model Presentation {
  id         String   @id @default(cuid())
  title      String
  topic      String   @db.VarChar(500)
  subject    String?  @db.VarChar(200)
  gradeLevel String?  @db.VarChar(100)
  emphasis   String?  @db.VarChar(500)
  /// Массив слайдов: [{ title, bullets: string[], notes?: string }]
  slides     Json
  /// Модель LLM, выдавшая результат (или 'stub' если ключа не было).
  model      String?
  authorId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([authorId])
}

/// Поурочный план (план конкретного урока: цели, этапы со временем, ДЗ).
/// Может ссылаться на тему КТП. Поддерживает ИИ-генерацию черновика.
model LessonPlan {
  id         String   @id @default(cuid())
  teacherId  String
  subjectId  String?
  classId    String?
  topicId    String?
  title      String
  date       DateTime?
  duration   Int      @default(45)
  objectives String?  @db.VarChar(2000)
  /// Этапы урока: [{ title, minutes, activity }]
  stages     Json
  homework   String?  @db.VarChar(2000)
  model      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([teacherId])
}

// ============ AGENT (проактивная мультиагентная система) ============

/// Лог доменных событий — шина для агентского движка. См. docs/ai-agents-blueprint.md.
model AgentEvent {
  id          String    @id @default(cuid())
  type        String    // grade.created | attendance.marked | test.completed | ...
  actorUserId String?
  studentId   String?
  classId     String?
  payload     Json
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([type, processedAt])
}

/// Правило: на какое событие реагировать и что делать. Для вкл/выкл сценариев.
model AgentRule {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  eventType String
  config    Json?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Элемент Панели агента (инбокс роли/пользователя).
model AgentItem {
  id         String    @id @default(cuid())
  ruleKey    String?
  eventId    String?
  forUserId  String?
  forRole    String?
  studentId  String?
  kind       String    // alert | task | suggestion | draft
  severity   String    @default("info") // info | warn | urgent
  title      String
  body       String    @db.VarChar(2000)
  payload    Json?
  status     String    @default("new") // new | in_progress | approved | done | dismissed
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  resolvedBy String?

  @@index([forUserId, status])
  @@index([forRole, status])
  @@index([studentId])
}

/// Аудит действий агента и реакций человека.
model AgentActionLog {
  id        String   @id @default(cuid())
  itemId    String?
  action    String   // created | approved | sent | dismissed | escalated
  byUserId  String?
  detail    Json?
  createdAt DateTime @default(now())
}

// ============ AI-АССИСТЕНТ ЯДРА (чат в разрезе роли) ============

/// Диалог пользователя с ассистентом ядра. История сохраняется —
/// ассистент «помнит» контекст между сессиями.
model AssistantConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("Новый диалог")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AssistantMessage[]

  @@index([userId, updatedAt])
}

model AssistantMessage {
  id             String                @id @default(cuid())
  conversationId String
  conversation   AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // user | assistant
  content        String                @db.VarChar(8000)
  createdAt      DateTime              @default(now())

  @@index([conversationId, createdAt])
}

// ============ БАЗА ЗНАНИЙ ШКОЛЫ ============

/// Документы-инструкции школы (режим работы, правила приёма, оплата...).
/// Ассистент ядра ищет по ним и отвечает «за менеджера» в рамках любой роли.
model KnowledgeDoc {
  id        String   @id @default(cuid())
  title     String
  category  String? // приём | оплата | режим | общее
  content   String   @db.Text
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

// ============ ПРИЁМНАЯ (CRM-воронка: звонок → зачисление) ============

enum AdmissionStage {
  lead // заявка/звонок
  testing // тестирование (математика/английский)
  psych // заключение психолога
  director // решение директора
  contract // договор + график оплат
  enrolled // зачислен (создан Student)
  rejected // отказ (причина — для retention-аналитики)
}

enum PaymentSchedule {
  monthly
  quarterly
  yearly
}

/// Лид приёмной. Один ребёнок — одна запись, ни один факт не теряется:
/// баллы теста, заключение психолога, решение, договор, причина ухода.
model AdmissionLead {
  id                String           @id @default(cuid())
  stage             AdmissionStage   @default(lead)
  childName         String
  targetGrade       Int
  parentName        String
  phone             String
  source            String? // звонок | instagram | сайт | рекомендация
  mathScore         Int?
  englishScore      Int?
  psychNote         String?          @db.VarChar(2000)
  decisionNote      String?          @db.VarChar(1000)
  contractAmount    Int? // сомов за период обучения
  paymentSchedule   PaymentSchedule?
  rejectReason      String?          @db.VarChar(1000)
  enrolledStudentId String? // Student.id после зачисления
  classId           String? // класс зачисления
  branchId          String? // филиал (multi-branch)
  sentToPsych       Boolean          @default(false) // отправлен на тестирование к психологу
  psychCaseId       String? // PsyCase (PRE-тест), если создан
  createdById       String // user.id (секретарь/ассистент директора)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([stage, updatedAt])
  @@index([branchId])
}

enum CcConflictStatus {
  green
  yellow
  red
}

enum CcExamType {
  sat
  ielts
  toefl
  ort
  csca
  opt
}

enum CcApplicationType {
  early_action
  early_decision
  regular_decision
}

enum CcAdmissionStatus {
  scouting
  document_prep
  submitted
  decision_pending
  offer_received
  rejected
  accepted_final
}

enum CcDocType {
  personal_statement
  essay
  cv
  brag_sheet
  recommendation
  portfolio
  transcript
  passport
  other
}

enum CcDocStatus {
  not_started
  draft
  in_review
  ready
  received
}

model CcProfile {
  id                 String           @id @default(cuid())
  studentId          String           @unique
  student            Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  counselorId        String?
  branchId           String?
  studentCountries   String[]
  studentMajor       String?
  studentMotivation  String?          @db.Text
  parentCountries    String[]
  parentBudgetUsd    Int?
  parentMajor        String?
  parentSafety       Boolean          @default(false)
  parentExpectations String?          @db.Text
  conflictStatus     CcConflictStatus @default(green)
  conflictComputedAt DateTime?
  riskFlagCleared    Boolean          @default(false)
  counselorComment   String?          @db.Text
  strategyAssigned   Boolean          @default(false)
  alumniAbroad       Boolean          @default(false)
  exams              CcExam[]
  applications       CcApplication[]
  documents          CcDocument[]
  meetings           CcMeeting[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([counselorId])
  @@index([conflictStatus])
  @@index([branchId])
}

model CcExam {
  id             String     @id @default(cuid())
  profileId      String
  profile        CcProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  examType       CcExamType
  testDate       DateTime?
  scoreCurrent   Float?
  scoreTarget    Float?
  isMock         Boolean    @default(false)
  verified       Boolean    @default(false)
  certificateUrl String?
  comment        String?
  createdAt      DateTime   @default(now())

  @@index([profileId])
}

model CcApplication {
  id                String             @id @default(cuid())
  profileId         String
  profile           CcProfile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  universityName    String
  country           String?
  program           String?
  applicationType   CcApplicationType?
  admissionStatus   CcAdmissionStatus  @default(scouting)
  deadlineDate      DateTime?
  decisionDate      DateTime?
  applicationId     String?
  submissionProof   String?
  scholarshipAmount String?
  scholarshipType   String?
  comment           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([profileId])
  @@index([admissionStatus])
  @@index([deadlineDate])
}

model CcDocument {
  id                String      @id @default(cuid())
  profileId         String
  profile           CcProfile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  docType           CcDocType
  status            CcDocStatus @default(not_started)
  fileUrl           String?
  teacherId         String?
  requestedDeadline DateTime?
  receivedAt        DateTime?
  requiredCount     Int?
  comment           String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([profileId])
}

model CcMeeting {
  id          String    @id @default(cuid())
  profileId   String
  profile     CcProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  counselorId String?
  meetingDate DateTime  @default(now())
  topic       String?
  notes       String?   @db.Text
  actionItems String?   @db.Text
  format      String?
  createdAt   DateTime  @default(now())

  @@index([profileId])
}
