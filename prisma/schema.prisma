generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ AUTH & ROLES ============

model User {
  id        String   @id @default(cuid())
  login     String   @unique
  email     String?  @unique
  password  String
  role      Role
  starLevel Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher Teacher?
  student Student?
  parent  Parent?
}

enum Role {
  super_admin
  analyst
  zavuch
  secretary
  teacher
  curator
  specialist
  student
  parent
}

// ============ SCHOOL STRUCTURE ============

model SchoolLevel {
  id        String  @id @default(cuid())
  name      String
  fromGrade Int
  toGrade   Int
  classes   Class[]
}

model Class {
  id      String      @id @default(cuid())
  grade   Int
  letter  String
  levelId String
  level   SchoolLevel @relation(fields: [levelId], references: [id])

  curatorId String?
  curator   Teacher? @relation("CuratorOf", fields: [curatorId], references: [id])

  students        Student[]
  groups          ClassGroup[]
  scheduleEntries ScheduleEntry[]
  homework        Homework[]
  news            News[]
}

model ClassGroup {
  id        String    @id @default(cuid())
  name      String
  classId   String
  class     Class     @relation(fields: [classId], references: [id])
  students  Student[] @relation("StudentGroups")
  transfersFrom GroupTransfer[] @relation("TransferFromGroup")
  transfersTo   GroupTransfer[] @relation("TransferToGroup")
}

model GroupTransfer {
  id           String              @id @default(cuid())
  studentId    String
  classId      String
  fromGroupId  String
  toGroupId    String
  requestedBy  String              // teacher.id who initiated
  approvedBy   String?             // teacher.id who approved (if status='approved')
  status       GroupTransferStatus @default(pending)
  rejectReason String?             @db.VarChar(500)
  createdAt    DateTime            @default(now())
  decidedAt    DateTime?

  fromGroup ClassGroup @relation("TransferFromGroup", fields: [fromGroupId], references: [id])
  toGroup   ClassGroup @relation("TransferToGroup",   fields: [toGroupId],   references: [id])

  @@index([classId, status, createdAt])
  @@index([studentId])
}

enum GroupTransferStatus {
  pending
  approved
  rejected
}

// ============ PEOPLE ============

model Teacher {
  id         String    @id @default(cuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id])
  firstName  String
  lastName   String
  middleName String?
  position   String?
  photo      String?
  hireDate   DateTime?

  subjects        TeacherSubject[]
  curatorOf       Class[]           @relation("CuratorOf")
  scheduleEntries ScheduleEntry[]
  substitutions   Substitution[]
  descriptors     TeacherDescriptor[]
  grades          Grade[]
  homework        Homework[]
}

/// Дескриптор педагога (по ТЗ): пометки о качестве работы, выговорах, штрафах,
/// повышениях, частых болезнях и т.п. с привязкой к учебному году.
/// Уровень доступа:
///   1 — общий: видим мы (super_admin), завучи и сам педагог
///   2 — только завучи и super_admin
///   3 — только super_admin
model TeacherDescriptor {
  id          String   @id @default(cuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  year        Int      // учебный год начала (например 2025 = 2025-2026)
  text        String   @db.VarChar(2000)
  accessLevel Int      @default(1) // 1 / 2 / 3
  authorId    String   // user.id создателя
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teacherId, year])
  @@index([accessLevel])
}

model Student {
  id          String        @id @default(cuid())
  userId      String?       @unique
  user        User?         @relation(fields: [userId], references: [id])
  firstName   String
  lastName    String
  middleName  String?
  dateOfBirth DateTime?
  photo       String?
  status      StudentStatus @default(permanent)
  classId     String
  class       Class         @relation(fields: [classId], references: [id])
  enrolledAt  DateTime      @default(now())

  groups      ClassGroup[]    @relation("StudentGroups")
  grades      Grade[]
  attendance  Attendance[]
  parentLinks ParentStudent[]
  incidents   BehaviorIncident[]

  medicalData   Json?
  familyData    Json?
  financialData Json?
}

enum StudentStatus {
  permanent
  conditional
  repeating
}

model Parent {
  id        String @id @default(cuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id])
  firstName String
  lastName  String
  phone     String?

  children ParentStudent[]
}

model ParentStudent {
  parentId  String
  studentId String
  parent    Parent  @relation(fields: [parentId], references: [id])
  student   Student @relation(fields: [studentId], references: [id])
  relation  String

  @@id([parentId, studentId])
}

// ============ SUBJECTS & WORKLOAD ============

model Subject {
  id    String  @id @default(cuid())
  name  String
  color String?

  teachers        TeacherSubject[]
  grades          Grade[]
  scheduleEntries ScheduleEntry[]
  homework        Homework[]
}

model TeacherSubject {
  id           String  @id @default(cuid())
  teacherId    String
  subjectId    String
  classId      String
  hoursPerWeek Int     @default(0)
  teacher      Teacher @relation(fields: [teacherId], references: [id])
  subject      Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId, classId])
}

/// Запись о передаче нагрузки от одного учителя к другому (декрет, болезнь, увольнение).
/// По ТЗ: новый учитель видит все учебные даты, темы и оценки за период до transferredAt
/// в режиме read-only. Записи накапливаются при каждой передаче, чтобы цепочка была видна.
model TeacherLoadTransfer {
  id              String   @id @default(cuid())
  fromTeacherId   String
  toTeacherId     String
  subjectId       String
  classId         String
  reason          String?  @db.VarChar(500) // декрет, длительная болезнь, увольнение и т.п.
  transferredAt   DateTime @default(now())
  transferredBy   String   // user.id (завуч/super_admin)

  @@index([toTeacherId, classId, subjectId])
  @@index([fromTeacherId, classId, subjectId])
}

// ============ SCHEDULE ============

model BellSchedule {
  id         String   @id @default(cuid())
  slotNumber Int
  startTime  String
  endTime    String
  type       SlotType

  entries ScheduleEntry[]
}

enum SlotType {
  lesson
  break_time
  breakfast
  lunch
  snack
  dismissal
}

model ScheduleEntry {
  id          String   @id @default(cuid())
  classId     String
  teacherId   String
  subjectId   String
  slotId      String
  dayOfWeek   Int
  periodStart DateTime
  periodEnd   DateTime

  class   Class        @relation(fields: [classId], references: [id])
  teacher Teacher      @relation(fields: [teacherId], references: [id])
  subject Subject      @relation(fields: [subjectId], references: [id])
  slot    BellSchedule @relation(fields: [slotId], references: [id])

  @@index([classId, dayOfWeek, periodStart, periodEnd])
  @@index([teacherId, dayOfWeek, periodStart, periodEnd])
}

model Substitution {
  id                  String   @id @default(cuid())
  date                DateTime
  originalTeacherId   String
  substituteTeacherId String
  classId             String
  subjectId           String
  slotId              String
  reason              String?
  createdAt           DateTime @default(now())

  substitute Teacher @relation(fields: [substituteTeacherId], references: [id])
}

// ============ GRADING ============

model GradeCategory {
  id                  String  @id @default(cuid())
  name                String
  weight              Int
  order               Int
  // По ТЗ: на модерацию идут только Контрольные / Зачёт / Триместровая / Итоговая / Экзамен
  requiresModeration  Boolean @default(false)
  // По ТЗ: тип "проверочная работа" — настраиваемый чекбокс (для отчёта № 4)
  isAssessment        Boolean @default(false)
  // По ТЗ: учителя могут создавать собственные категории только при разрешении админа
  enabledForTeachers  Boolean @default(false)

  grades Grade[]
}

model Grade {
  id         String      @id @default(cuid())
  studentId  String
  subjectId  String
  categoryId String
  teacherId  String
  periodId   String
  value      Int
  scale      GradeScale  @default(FIVE)
  comment    String?     @db.VarChar(500)
  date       DateTime
  status     GradeStatus @default(draft)
  // EduPage: родитель/ученик «подписывает» оценку (подтверждает, что видел)
  parentSignedAt DateTime?
  parentSignedBy String?  // user.id родителя/ученика
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  student  Student        @relation(fields: [studentId], references: [id])
  subject  Subject        @relation(fields: [subjectId], references: [id])
  category GradeCategory  @relation(fields: [categoryId], references: [id])
  teacher  Teacher        @relation(fields: [teacherId], references: [id])
  period   AcademicPeriod @relation(fields: [periodId], references: [id])
  auditLog GradeAuditLog[]

  @@index([studentId, subjectId, periodId])
  @@index([status])
}

enum GradeStatus {
  draft
  submitted
  moderated
  published
}

enum GradeScale {
  FIVE
  TWELVE
  HUNDRED
  LETTER
}

model GradeAuditLog {
  id        String   @id @default(cuid())
  gradeId   String
  userId    String
  oldValue  Int?
  newValue  Int?
  action    String
  createdAt DateTime @default(now())

  grade Grade @relation(fields: [gradeId], references: [id])
}

// ============ ATTENDANCE ============

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  date      DateTime
  status    AttendanceStatus
  reason    String?          @db.VarChar(300) // причина отсутствия/освобождения (болезнь, справка и т.п.)

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
}

enum AttendanceStatus {
  present
  absent
  late
  excused
  trip
  quarantine
}

// ============ ACADEMIC PERIODS ============

model AcademicPeriod {
  id        String     @id @default(cuid())
  name      String
  type      PeriodType
  startDate DateTime
  endDate   DateTime
  isActive  Boolean    @default(false)

  grades Grade[]
}

enum PeriodType {
  trimester
  holiday
  quarantine
}

// ============ HOMEWORK ============

model Homework {
  id          String   @id @default(cuid())
  classId     String
  subjectId   String
  teacherId   String
  description String
  dueDate     DateTime
  createdAt   DateTime @default(now())

  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])
}

// ============ BEHAVIOR ============

model BehaviorIncident {
  id             String         @id @default(cuid())
  studentId      String
  reporterId     String
  type           String
  description    String
  status         IncidentStatus @default(pending)
  moderatedBy    String?
  moderatedAt    DateTime?
  parentNotified Boolean        @default(false)
  createdAt      DateTime       @default(now())

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId, createdAt])
}

enum IncidentStatus {
  pending
  moderated
  resolved
}

// ============ NEWS ============

model News {
  id          String   @id @default(cuid())
  title       String
  content     String
  type        NewsType
  authorId    String
  classId     String?
  class       Class?   @relation(fields: [classId], references: [id])
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum NewsType {
  school
  staff
  class_note
}

// ============ URGENT ISSUES ============

model UrgentIssue {
  id          String        @id @default(cuid())
  title       String
  description String
  priority    IssuePriority
  status      IssueStatus   @default(open)
  authorId    String
  visibleTo   String[]      // role names: ['zavuch', 'curator', 'super_admin']
  classId     String?
  studentId   String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum IssuePriority {
  high
  medium
  low
}

enum IssueStatus {
  open
  in_progress
  resolved
  closed
}

// ============ INCIDENTS ============

model Incident {
  id          String        @id @default(cuid())
  title       String
  description String
  type        IncidentType
  severity    IssuePriority
  status      IssueStatus   @default(open)
  authorId    String
  classId     String?
  studentId   String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum IncidentType {
  behavior
  health
  equipment
  safety
  other
}

// ============ CHAT ============

model ChatMessage {
  id        String   @id @default(cuid())
  senderId  String
  roomId    String
  content   String
  fileUrl   String?
  createdAt DateTime @default(now())
}

// ============ CALENDAR ============

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.VarChar(1000)
  date        DateTime
  endDate     DateTime?
  type        String   @default("event") // event | holiday | exam | meeting | deadline
  classId     String?  // null = общешкольное
  audience    String[] @default([]) // роли, для кого видно; пусто = все
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

// ============ CURRICULUM PLAN (КТП) ============

model CurriculumPlan {
  id        String   @id @default(cuid())
  subjectId String
  classId   String
  periodId  String?
  teacherId String?
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topics CurriculumTopic[]

  @@index([subjectId, classId])
}

model CurriculumTopic {
  id        String   @id @default(cuid())
  planId    String
  plan      CurriculumPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  order     Int
  title     String
  hours     Int      @default(1)
  plannedAt DateTime?
  done      Boolean  @default(false)

  @@index([planId, order])
}

// ============ ACHIEVEMENTS ============

model Achievement {
  id          String   @id @default(cuid())
  studentId   String
  title       String
  description String?  @db.VarChar(1000)
  category    String   @default("academic") // academic | sport | art | social | other
  level       String   @default("school")   // school | district | city | republic | international
  place       String?  // 1 место, призёр, участник и т.п.
  date        DateTime
  authorId    String
  createdAt   DateTime @default(now())

  @@index([studentId])
}

// ============ PORTFOLIO ============

model PortfolioEntry {
  id          String   @id @default(cuid())
  studentId   String
  type        String   @default("work") // work | certificate | project | reflection
  title       String
  description String?  @db.VarChar(1000)
  fileUrl     String?
  fileName    String?
  date        DateTime
  authorId    String
  createdAt   DateTime @default(now())

  @@index([studentId])
}

// ============ LIBRARY ============

model LibraryItem {
  id        String   @id @default(cuid())
  title     String
  author    String?
  isbn      String?
  category  String?  // учебник | художественная | методическая
  total     Int      @default(1)
  available Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loans LibraryLoan[]
}

model LibraryLoan {
  id         String   @id @default(cuid())
  itemId     String
  item       LibraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  studentId  String?
  teacherId  String?
  borrowerName String? // на случай ручной выдачи
  takenAt    DateTime @default(now())
  dueAt      DateTime
  returnedAt DateTime?

  @@index([itemId])
  @@index([studentId])
}

// ============ SPECIALIST CABINETS ============

enum SpecialistKind {
  speech
  psych
  medical
}

model SpecialistSession {
  id           String   @id @default(cuid())
  kind         SpecialistKind
  studentId    String
  specialistId String   // user.id специалиста
  date         DateTime
  startTime    String?  // HH:mm
  endTime      String?
  groupName    String?  // для групповых занятий
  note         String?  @db.VarChar(1000)
  createdAt    DateTime @default(now())

  @@index([kind, date])
  @@index([studentId])
}

model SpecialistRecommendation {
  id           String   @id @default(cuid())
  kind         SpecialistKind @default(psych)
  studentId    String
  specialistId String
  text         String   @db.VarChar(2000)
  date         DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([studentId])
}

model SpecialistProgress {
  id           String   @id @default(cuid())
  kind         SpecialistKind @default(speech)
  studentId    String
  specialistId String
  metric       String   // что измеряем (звук «Р», тревожность и т.п.)
  value        Int      // 0..100 прогресс
  note         String?  @db.VarChar(500)
  date         DateTime
  createdAt    DateTime @default(now())

  @@index([studentId, metric])
}

// ============ STAFF / HR ============

model StaffMember {
  id        String   @id @default(cuid())
  userId    String?  // если есть учётка
  firstName String
  lastName  String
  middleName String?
  position  String
  department String?  // АХЧ, бухгалтерия, охрана, кухня и т.п.
  phone     String?
  email     String?
  hireDate  DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ DOCUMENTS (полиморфно) ============

enum DocumentOwnerType {
  student
  teacher
  staff
  school
}

model DocumentRecord {
  id        String   @id @default(cuid())
  ownerType DocumentOwnerType
  ownerId   String?  // null для общешкольных
  kind      String   // СНИЛС, полис ОМС, приказ, договор и т.п.
  title     String
  number    String?
  issuedAt  DateTime?
  expiresAt DateTime?
  fileUrl   String?
  fileName  String?
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerType, ownerId])
}

// ============ OLYMPIADS & PROJECTS ============

model Olympiad {
  id        String   @id @default(cuid())
  name      String
  subjectId String?
  level     String   @default("school") // school | district | city | republic | international
  stage     String?  // отборочный | финал
  date      DateTime
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participations OlympiadParticipation[]
}

model OlympiadParticipation {
  id         String   @id @default(cuid())
  olympiadId String
  olympiad   Olympiad @relation(fields: [olympiadId], references: [id], onDelete: Cascade)
  studentId  String
  result     String?  // балл / место / диплом
  createdAt  DateTime @default(now())

  @@index([olympiadId])
  @@index([studentId])
}

// ============ SCHOOL EVENTS ============

model SchoolEvent {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.VarChar(2000)
  date        DateTime
  endDate     DateTime?
  location    String?
  organizerId String?  // user.id
  audience    String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

// ============ STUDIOS / CLUBS ============

model Studio {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.VarChar(1000)
  leaderId    String?  // teacher/user id
  leaderName  String?
  schedule    String?  // "Пн/Ср 15:00"
  capacity    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments StudioEnrollment[]
}

model StudioEnrollment {
  id         String   @id @default(cuid())
  studioId   String
  studio     Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  studentId  String
  enrolledAt DateTime @default(now())

  @@unique([studioId, studentId])
}

// ============ TRIPS ============

model Trip {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.VarChar(1000)
  destination String?
  date        DateTime
  returnDate  DateTime?
  classId     String?
  responsibleId String? // user.id
  cost        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participants TripParticipant[]
}

model TripParticipant {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  studentId String
  consent   Boolean  @default(false) // согласие родителей
  paid      Boolean  @default(false)

  @@unique([tripId, studentId])
}

// ============ ACCOUNTING ============

enum InvoiceStatus {
  pending
  partial
  paid
  cancelled
}

model FeeInvoice {
  id        String   @id @default(cuid())
  studentId String
  title     String   // "Обучение, сентябрь" и т.п.
  period    String?  // месяц/триместр
  amount    Int      // в сомах
  status    InvoiceStatus @default(pending)
  dueDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]

  @@index([studentId])
  @@index([status])
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Int
  method    String?  // нал | карта | банк
  paidAt    DateTime @default(now())
  note      String?

  @@index([invoiceId])
}

model Expense {
  id        String   @id @default(cuid())
  category  String   // зарплата | коммуналка | закуп | ремонт
  title     String
  amount    Int
  date      DateTime
  authorId  String
  createdAt DateTime @default(now())

  @@index([category])
  @@index([date])
}

// ============ KITCHEN / MEALS ============

enum MealType {
  breakfast
  lunch
  snack
}

model MealMenu {
  id        String   @id @default(cuid())
  date      DateTime
  meal      MealType
  dish      String
  calories  Int?
  cost      Int?
  createdAt DateTime @default(now())

  @@index([date, meal])
}

model MealPlan {
  id        String   @id @default(cuid())
  classId   String
  date      DateTime
  meal      MealType
  count     Int      @default(0) // сколько питается
  createdAt DateTime @default(now())

  @@unique([classId, date, meal])
}

// ============ MAINTENANCE / АХЧ ============

enum MaintenanceStatus {
  open
  in_progress
  done
  cancelled
}

model Asset {
  id        String   @id @default(cuid())
  name      String
  inventoryNo String?
  location  String?  // кабинет/этаж
  category  String?  // мебель | техника | инвентарь
  quantity  Int      @default(1)
  condition String?  // новое | рабочее | требует ремонта | списано
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceRequest {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.VarChar(1000)
  location    String?
  priority    IssuePriority @default(medium)
  status      MaintenanceStatus @default(open)
  assigneeId  String?  // staff/user id
  assigneeName String?
  authorId    String
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

// ============ LESSON TOPIC (тема урока, EduPage) ============

model LessonTopic {
  id        String   @id @default(cuid())
  classId   String
  subjectId String
  teacherId String?
  date      DateTime
  topic     String   @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, subjectId, date])
  @@index([classId, subjectId])
}

// ============ HOMEWORK COMPLETION (отметка «выполнено») ============

model HomeworkCompletion {
  id         String   @id @default(cuid())
  homeworkId String
  studentId  String
  doneAt     DateTime @default(now())

  @@unique([homeworkId, studentId])
  @@index([homeworkId])
}

// ============ ЗАЯВЛЕНИЯ / ЗАПИСКА ОБ ОТСУТСТВИИ (Модуль 4) ============

enum ApplicationType {
  absence   // отпросить / записка об отсутствии
  leave     // отпуск
  other
}

enum ApplicationStatus {
  pending
  approved
  rejected
}

model Application {
  id         String   @id @default(cuid())
  type       ApplicationType   @default(absence)
  studentId  String
  classId    String?
  authorId   String   // user.id родителя/ученика, подавшего заявление
  reason     String   @db.VarChar(1000)
  fromDate   DateTime
  toDate     DateTime?
  status     ApplicationStatus @default(pending)
  reviewedBy String?  // user.id завуча/учителя
  reviewNote String?  @db.VarChar(500)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([studentId])
}

// ============ ОПРОСЫ / ГОЛОСОВАНИЯ (Модуль 5) ============

model Survey {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.VarChar(1000)
  options     String[] // варианты ответа
  audience    String[] @default([]) // роли; пусто = все
  authorId    String
  closesAt    DateTime?
  createdAt   DateTime @default(now())

  votes SurveyVote[]
}

model SurveyVote {
  id          String   @id @default(cuid())
  surveyId    String
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId      String
  optionIndex Int
  createdAt   DateTime @default(now())

  @@unique([surveyId, userId])
  @@index([surveyId])
}

// ============ ЗАКАЗ СТОЛОВОЙ (Модуль 6, поверх MealMenu) ============

model MealOrder {
  id        String   @id @default(cuid())
  date      DateTime
  meal      MealType
  studentId String
  status    String   @default("ordered") // ordered | cancelled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date, meal])
  @@index([date])
}

// ============ СОГЛАСИЯ РОДИТЕЛЕЙ + БЮРО НАХОДОК (Модуль 7) ============

model Consent {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.VarChar(1000)
  eventDate   DateTime?
  classId     String?
  authorId    String
  createdAt   DateTime @default(now())

  responses ConsentResponse[]
}

model ConsentResponse {
  id        String   @id @default(cuid())
  consentId String
  consent   Consent  @relation(fields: [consentId], references: [id], onDelete: Cascade)
  studentId String
  agreed    Boolean
  signedBy  String   // user.id родителя
  signedAt  DateTime @default(now())

  @@unique([consentId, studentId])
}

model LostFoundItem {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.VarChar(500)
  location    String?
  status      String   @default("found") // found | claimed | returned
  foundAt     DateTime @default(now())
  authorId    String
  createdAt   DateTime @default(now())
}

// ============ ТЕСТЫ С АВТОПРОВЕРКОЙ (Модуль 8, EduPage e-learning) ============

enum TestStatus {
  draft
  published
  closed
}

enum QuestionType {
  single    // один правильный вариант
  multiple  // несколько правильных
  number    // числовой ответ
  text      // открытый (проверяет учитель, авто-0)
}

model Test {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.VarChar(1000)
  subjectId   String?
  classId     String?
  authorId    String
  status      TestStatus @default(published)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions TestQuestion[]
  attempts  TestAttempt[]

  @@index([classId])
  @@index([authorId])
}

model TestQuestion {
  id             String   @id @default(cuid())
  testId         String
  test           Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  order          Int
  text           String   @db.VarChar(1000)
  type           QuestionType @default(single)
  options        String[] @default([])    // варианты (для single/multiple)
  correctAnswers String[] @default([])    // правильные: индексы вариантов или значение (number)
  points         Int      @default(1)

  @@index([testId, order])
}

model TestAttempt {
  id          String   @id @default(cuid())
  testId      String
  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  studentId   String
  score       Int      @default(0)
  maxScore    Int      @default(0)
  submittedAt DateTime @default(now())

  answers TestAnswer[]

  @@unique([testId, studentId])
  @@index([testId])
}

model TestAnswer {
  id            String   @id @default(cuid())
  attemptId     String
  attempt       TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId    String
  answer        String[] @default([])
  isCorrect     Boolean  @default(false)
  pointsAwarded Int      @default(0)

  @@index([attemptId])
}
