// ============ ПСИХОЛОГИЧЕСКАЯ СЛУЖБА (eSPSMS) ============
// Кейс-менеджмент психолога с DAP-сессиями, версионируемыми методиками,
// уровнями риска и safeguarding. RLS — на уровне API (psy-scope.ts): психолог
// видит только свои кейсы + где он принятый коллаборатор.

enum PsyRisk {
  green
  yellow
  red
}

enum PsyCaseStatus {
  new
  in_progress
  paused
  closed
}

enum PsySessionType {
  primary_diagnosis
  planned
  emergency
  parent_meeting
  teacher_meeting
  group
}

enum PsyCollabStatus {
  pending
  accepted
  declined
}

// Исход курса (≈6 сессий): по итогам психолог фиксирует результат.
enum PsyOutcome {
  in_progress
  improved // явные улучшения — кейс закрывается
  repeat // нет улучшений — новый раунд с другими методиками
  referred // вне полномочий — направление к узкому специалисту
}

// Этап 9: субъект кейса психолога — 4 кабинета (ученик/родитель/учитель/группа-класс).
enum PsyCaseStage {
  assessment
  diagnosis
  ips
  intervention
  review
  closed
}

enum PsySubject {
  student
  parent
  teacher
  group
}

model PsyCase {
  id                String        @id @default(cuid())
  // Этап 9: кейс может вестись не только по ученику, но и по родителю/учителю/группе.
  subjectType       PsySubject    @default(student)
  subjectId         String? // id субъекта при parent/teacher/group; для student дублирует studentId
  subjectName       String? // кэш имени субъекта (родитель/учитель/класс) для отображения
  studentId         String? // заполняется при subjectType=student (обратная совместимость)
  ownerId           String        // user.id психолога-владельца
  title             String
  reason            String?       @db.VarChar(1000)
  riskLevel         PsyRisk       @default(green)
  riskJustification String?       @db.VarChar(1000) // обязателен при red (валидируется в API)
  status            PsyCaseStatus @default(new)
  stage             PsyCaseStage  @default(assessment)
  summary           String? // итоговое заключение по курсу (6 сессий)
  courseRound       Int           @default(1) // номер раунда из ~6 сессий
  outcome           PsyOutcome    @default(in_progress)
  isIntake          Boolean       @default(false) // PRE-тест при поступлении (из приёмки)
  intakeVerdict     String?       // заключение экспресс-теста поступающего: recommended | not_recommended | redirected
  openedAt          DateTime      @default(now())
  closedAt          DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  sessions      PsySession[]
  collaborators PsyCaseCollaborator[]
  tests         PsyTestResult[]
  ips           PsyIps[]
  interventions PsyIntervention[]
  measurements  PsyMeasurement[]
  alerts        PsyAlert[]
  aiFeedback    PsyAiFeedback[]
  referrals     PsyReferral[]

  @@index([studentId])
  @@index([ownerId])
  @@index([riskLevel])
}

// Направление к узкому специалисту (психиатр/логопед/др.) по итогам курса.
model PsyReferral {
  id        String   @id @default(cuid())
  caseId    String
  case      PsyCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  target    String // psychiatrist | speech | medical | other
  note      String?
  createdBy String
  createdAt DateTime @default(now())

  @@index([caseId])
}

model PsyCaseCollaborator {
  id          String          @id @default(cuid())
  caseId      String
  case        PsyCase         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId      String // приглашённый психолог
  status      PsyCollabStatus @default(pending)
  requestedAt DateTime        @default(now())
  decidedAt   DateTime?

  @@unique([caseId, userId])
  @@index([userId])
}

model PsySession {
  interventionId String?
  intervention   PsyIntervention? @relation(fields: [interventionId], references: [id])
  id              String         @id @default(cuid())
  caseId          String
  case            PsyCase        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorId        String // user.id психолога, проводившего сессию
  templateId      String? // использованная методика
  date            DateTime       @default(now())
  type            PsySessionType @default(planned)
  rawNote         String? // оригинал психолога / транскрипт (НЕ перезаписывается AI)
  dapData         String?
  dapAssessment   String?
  dapPlan         String?
  qualNote        String? // качественное наблюдение «до/после» (стал спокойнее и т.п.)
  aiDraft         Json? // версия от AI отдельно (anti-hallucination)
  isHumanVerified Boolean        @default(false)
  verifiedAt      DateTime?
  audioKey        String? // ключ аудио в MinIO
  createdAt       DateTime       @default(now())

  @@index([caseId])
  @@index([authorId])
  @@index([interventionId])
}

model PsyDiagnosticTemplate {
  id               String   @id @default(cuid())
  name             String
  version          Int      @default(1)
  parentTemplateId String? // линейка версий (для версионирования)
  authorId         String // senior_psychologist user.id
  schema           Json // вопросы / шкалы 1..10 / симптомы / файловые поля
  scaleConfig      Json?
  mappingRule      Json? // правило пересчёта относительно прошлой версии (патч аналит. коллапса)
  gradeBand        String? // ступень: "1-4" | "5-9" | "10-11"
  direction        String? // направление: адаптация | тревожность | мотивация | агрессия_депрессия | социометрия | профориентация | стресс
  isBase           Boolean  @default(false) // поставляемый базовый шаблон — нередактируем, только копия
  isPublished      Boolean  @default(false) // опубликован старшим психологом на всю службу
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  @@index([parentTemplateId])
  @@index([isActive])
}

model PsyTestResult {
  id               String   @id @default(cuid())
  caseId           String
  case             PsyCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sessionId        String?
  templateId       String
  templateVersion  Int      @default(1)
  rawScores        Json?
  computedScales   Json?
  imageKey         String? // проективный рисунок в MinIO (оригинал)
  aiInterpretation String?
  isHumanVerified  Boolean  @default(false)
  date             DateTime @default(now())

  @@index([caseId])
}

model PsyMeasurement {
  id              String   @id @default(cuid())
  caseId          String
  case            PsyCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  templateId      String?
  templateVersion Int      @default(1)
  metric          String
  value           Int
  date            DateTime @default(now())

  @@index([caseId, metric])
}

model PsyScreeningCampaign {
  id            String               @id @default(cuid())
  title         String
  gradeBand     String
  grade         Int?
  templateId    String
  createdBy     String
  branchId      String?
  status        String               @default("active")
  riskThreshold Int?
  openedAt      DateTime             @default(now())
  closedAt      DateTime?
  createdAt     DateTime             @default(now())
  results       PsyScreeningResult[]

  @@index([status])
  @@index([gradeBand])
}

model PsyScreeningResult {
  id          String               @id @default(cuid())
  campaignId  String
  campaign    PsyScreeningCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  rawScores   Json?
  score       Int?
  isRisk      Boolean              @default(false)
  completedAt DateTime             @default(now())

  @@unique([campaignId, studentId])
  @@index([campaignId, isRisk])
  @@index([studentId])
}

// Safeguarding-алерт (UC-5): слепое экстренное уведомление координатору.
// На устройстве — стандартный текст без имён; детали — только после входа.
enum PsyAlertStatus {
  open
  in_progress
  resolved
}

model PsyAlert {
  id        String         @id @default(cuid())
  caseId    String
  case      PsyCase        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  reason    String // обоснование критического риска (видно ТОЛЬКО в закрытом контуре)
  status    PsyAlertStatus @default(open)
  takenBy   String?
  takenAt   DateTime?
  // Авто-эскалация (UC-5+): если сигнал не взят в работу за N часов — поднимаем директору.
  escalatedAt    DateTime? // момент первой эскалации директору
  remindCount    Int       @default(0) // сколько напоминаний отправлено
  lastNotifiedAt DateTime? // последнее напоминание (для интервала)
  createdAt DateTime       @default(now())

  @@index([status])
  @@index([caseId])
}

model PsyAiFeedback {
  id        String   @id @default(cuid())
  caseId    String
  case      PsyCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sessionId String?
  rating    Int      // 1..5 — оценка качества ИИ-черновика DAP
  source    String?  // llm | local — какой контур сгенерил черновик
  comment   String?
  createdBy String    // психолог (user.id)
  createdAt DateTime @default(now())

  @@index([caseId])
}

model PsyIps {
  id            String            @id @default(cuid())
  caseId        String
  case          PsyCase           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  version       Int               @default(1)
  parentIpsId   String?
  status        String            @default("draft")
  approvedAt    DateTime?
  approvedBy    String?
  createdBy     String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  goals         PsyIpsGoal[]
  interventions PsyIntervention[]

  @@index([caseId])
}

model PsyIpsGoal {
  id          String    @id @default(cuid())
  ipsId       String
  ips         PsyIps    @relation(fields: [ipsId], references: [id], onDelete: Cascade)
  specific    String
  measurable  String?
  achievable  String?
  relevant    String?
  timeBound   String?
  deadline    String
  directions  Json?
  achieved    Boolean   @default(false)
  achievedAt  DateTime?

  @@index([ipsId])
}

model PsyIntervention {
  id              String       @id @default(cuid())
  caseId          String
  case            PsyCase      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  ipsId           String
  ips             PsyIps       @relation(fields: [ipsId], references: [id], onDelete: Cascade)
  plannedMeetings Int          @default(5)
  status          String       @default("active")
  startedAt       DateTime     @default(now())
  completedAt     DateTime?
  sessions        PsySession[]

  @@index([caseId])
  @@index([ipsId])
}

