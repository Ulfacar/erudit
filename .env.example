DATABASE_URL="postgresql://erudit:erudit@localhost:5432/erudit?schema=public"
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"
REDIS_URL="redis://localhost:6379"
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"

# ИИ-генератор презентаций (OpenRouter). Без ключа фича отдаёт демо-каркас (стаб).
OPENROUTER_API_KEY=""
# Необязательно: модель OpenRouter (по умолчанию anthropic/claude-3.5-sonnet)
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"

# Telegram-канал доставки уведомлений агента. Без токена — внутренний инбокс /agent.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""          # username бота без @ (для deep-link t.me/<bot>?start=...)
TELEGRAM_WEBHOOK_SECRET=""        # произвольная строка; защищает webhook
