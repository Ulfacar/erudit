# secrets / temp (НЕ коммитить — приватные ключи!)
vapid-*.tmp.json

# e2e generated artifacts (сессионные токены + отчёты — не в гит)
e2e/.auth/
e2e/.report/
e2e/.results/

# исходники Эмира (vision-деки, аудио) — локально; в гит идёт только school/deck
school/*
